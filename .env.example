# === GCP Configuration ===
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# === Gemini API (Vertex AI) ===
# Authenticate via: gcloud auth application-default login
# The Live API (voice) routes to us-central1 automatically.
# NOOR_LIVE_API_LOCATION=us-central1

# === Firestore ===
FIRESTORE_DATABASE=(default)

# === Browser Configuration ===
# Strategy 2 (RECOMMENDED FOR WINDOWS): Use system Edge/Chrome — no Chromium download needed
NOOR_BROWSER_CHANNEL=msedge
# Strategy 1 (FALLBACK): Connect to externally-launched browser via CDP
# NOOR_CDP_ENDPOINT=http://localhost:9222
# Strategy 3 (Docker/Cloud Run): Leave both unset to use bundled Playwright Chromium

# === App Configuration ===
NOOR_LOG_LEVEL=INFO
NOOR_BROWSER_HEADLESS=true
NOOR_HOST=0.0.0.0
NOOR_PORT=8080
NOOR_STREAMING_MODE=true

# === Session Backend ===
# "memory" (default) for local dev, "vertex" for GCP production, "database" for SQLite/PostgreSQL
NOOR_SESSION_BACKEND=memory

# === CORS ===
# Comma-separated list of allowed origins (in addition to localhost)
# NOOR_ALLOWED_ORIGINS=https://noor-agent-xxxxx.run.app

# === Rate Limiting ===
# Max WebSocket connections per IP per minute
NOOR_RATE_LIMIT=10
