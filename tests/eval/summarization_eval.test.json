{
  "eval_set_id": "noor_summarization_tests",
  "name": "Noor summarization agent tests",
  "description": "Eval cases for page reading, content extraction, and summarization",
  "eval_cases": [
    {
      "eval_id": "read_headlines",
      "conversation": [
        {
          "invocation_id": "inv-001",
          "user_content": {
            "parts": [{"text": "Read me the headlines on this page"}],
            "role": "user"
          },
          "final_response": {
            "parts": [{"text": "Here are the headlines I can see on the page."}],
            "role": "model"
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "analyze_current_page",
                "args": {"user_intent": "reading headlines"}
              }
            ],
            "intermediate_responses": []
          }
        }
      ],
      "session_input": {
        "app_name": "noor",
        "user_id": "test_user",
        "state": {}
      }
    },
